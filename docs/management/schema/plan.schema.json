{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Management plan document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "current_phase",
    "goal",
    "active_items",
    "next_actions",
    "blockers",
    "risks",
    "updated_at"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "current_phase": {
      "type": "string"
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "success_criteria"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "active_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "related_phase",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "blocked"
            ]
          },
          "related_phase": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "action",
          "owner",
          "exit_signal"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "exit_signal": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "impact",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    }
  }
}
