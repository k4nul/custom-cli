{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Management handoff document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "current_state",
    "done",
    "in_progress",
    "next_recommended",
    "open_risks",
    "verification_pending",
    "updated_at"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "repo_shape",
        "source_of_truth"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "repo_shape": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "source_of_truth": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "done": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    "in_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "next_step"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "next_step": {
            "type": "string"
          }
        }
      }
    },
    "next_recommended": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "action",
          "why"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        }
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "impact",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "verification_pending": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    }
  }
}
