{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Management decisions document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "decisions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "date",
          "context",
          "decision",
          "rationale",
          "impact",
          "alternatives_considered"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "accepted",
              "superseded",
              "proposed"
            ]
          },
          "date": {
            "type": "string"
          },
          "context": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "decision": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "impact": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "alternatives_considered": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "option",
                "reason_not_selected"
              ],
              "properties": {
                "option": {
                  "type": "string"
                },
                "reason_not_selected": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
