{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Management phases document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "phase_order",
    "phases"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "phase_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "objective",
          "entry_criteria",
          "required_inputs",
          "outputs",
          "recommended_actions",
          "exit_criteria",
          "status_allowed"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "objective": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "entry_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "recommended_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "exit_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "status_allowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "pending",
                "in_progress",
                "completed",
                "blocked"
              ]
            }
          }
        }
      }
    }
  }
}
